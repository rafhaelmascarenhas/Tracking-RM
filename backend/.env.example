DATABASE_URL="postgresql://user:password@host:5432/rm_app"

# Acesso ao painel: senha unica trocada por um JWT de 30 dias.
# Sem PANEL_PASSWORD a auth fica DESLIGADA (ok em dev, nunca em producao).
# PANEL_JWT_SECRET e obrigatorio junto com a senha: string aleatoria longa
# (ex: openssl rand -base64 48). Trocar o segredo desloga todo mundo.
PANEL_PASSWORD="senha-do-painel"
PANEL_JWT_SECRET="string-aleatoria-longa"

# Supabase JWT secret (found in Project Settings > API)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

PORT=3001

# URL pública do backend (a uazapi precisa alcançá-la para entregar webhooks).
# Em dev local use um túnel (ex: ngrok). Sem isso, cai no host da requisição.
PUBLIC_BASE_URL="https://seu-dominio-publico.com"
