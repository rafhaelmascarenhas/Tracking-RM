DATABASE_URL="postgresql://user:password@host:5432/rm_app"

# Supabase JWT secret (found in Project Settings > API)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

PORT=3001

# URL pública do backend (a uazapi precisa alcançá-la para entregar webhooks).
# Em dev local use um túnel (ex: ngrok). Sem isso, cai no host da requisição.
PUBLIC_BASE_URL="https://seu-dominio-publico.com"
