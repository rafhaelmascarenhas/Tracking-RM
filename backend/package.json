    "crypto": "^1.0.1",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jose": "^5.3.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
